extends ../layout

block content
  h1= title
  p
    strong Book:
    |  
    a(href=bookinstance.book.url)= bookinstance.book.title
  p
    strong Imprint:
    |  #{bookinstance.imprint}
  p
    strong Status:
    |  #{bookinstance.status}
  if bookinstance.due_back
    p
      strong Due back:
      |  #{bookinstance.due_back.toDateString()}
